# 所有文本文件在仓库内统一用 LF，checkout 到 Windows 时转 CRLF
* text=auto

# Unity 资产文件强制 LF
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.asset text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.controller text eol=lf
*.anim text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf

# 二进制文件，不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.tif binary
*.psd binary
*.wav binary
*.mp3 binary
*.ogg binary
*.fbx binary
*.blend binary
*.unitypackage binary
*.dll binary
*.so binary
*.dylib binary
